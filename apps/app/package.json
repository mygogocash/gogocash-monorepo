{
  "name": "@gogocash/mobile",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "gototrack:dev-client": "node scripts/gototrack-dev-client.mjs",
    "gototrack:artifact": "node scripts/gototrack-artifact.mjs",
    "prepare:web-metadata": "node scripts/generate-web-metadata.mjs",
    "sync:i18n": "node scripts/sync-i18n-catalogs.mjs",
    "gen:i18n-review": "node scripts/gen-i18n-review.mjs",
    "gototrack:preflight": "node scripts/gototrack-preflight.mjs",
    "staging:inject-auth-wallet": "node scripts/inject-staging-auth-wallet.mjs",
    "staging:maestro-wallet": "node scripts/inject-staging-auth-wallet.mjs /wallet && maestro test .maestro/flows/wallet-authenticated.yaml",
    "export:web": "npm run prepare:web-metadata && NODE_PATH=./node_modules expo export --platform web",
    "test": "vitest run --config vitest.config.ts",
    "test:full": "npm run test && npm run test:render && npm run typecheck && npm run export:web -- --output-dir /tmp/gogocash-expo-full-test-export",
    "test:flows": "vitest run --config vitest.config.ts src/__tests__/frontend-user-flow-parity.test.ts",
    "test:security": "vitest run --config vitest.config.ts src/__tests__/security-pentest.test.ts",
    "test:gototrack": "vitest run --config vitest.config.ts src/__tests__/gototrack-*.test.ts && vitest run --config vitest.render.config.ts src/__tests__/customer-gototrack.render.test.tsx src/__tests__/gototrack-*.render.test.tsx",
    "test:gototrack:api": "npm run test -w gogocash-api -- --testPathPatterns=gototrack --runInBand",
    "test:render": "vitest run --config vitest.render.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "measure:bundle": "node scripts/measure-web-bundle.mjs",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:maestro": "maestro test .maestro/flows/",
    "bug-hunt:maestro": "maestro test .maestro/flows/home.yaml .maestro/flows/auth-guard.yaml .maestro/flows/wallet-profile-auth-guard.yaml",
    "build:preview": "eas build --profile preview",
    "build:production": "eas build --profile production",
    "postinstall": "node scripts/patch-expo-firebase-core-gradle.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/anuphan": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo/metro-runtime": "~57.0.2",
    "@react-native-community/datetimepicker": "9.1.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "5.101.2",
    "expo": "^57.0.0",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-localization": "~57.0.0",
    "expo-modules-core": "~57.0.1",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-updates": "~57.0.4",
    "firebase": "^12.14.0",
    "phosphor-react-native": "^3.0.6",
    "posthog-react-native": "4.53.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-intl": "^10.1.14",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "14.0.1",
    "@types/node": "^26.0.1",
    "@types/react": "*",
    "babel-preset-expo": "~57.0.0",
    "happy-dom": "^20.9.0",
    "react-test-renderer": "19.2.7",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  }
}
