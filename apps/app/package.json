{
  "name": "@gogocash/mobile",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "gototrack:dev-client": "node scripts/gototrack-dev-client.mjs",
    "gototrack:artifact": "node scripts/gototrack-artifact.mjs",
    "prepare:web-metadata": "node scripts/generate-web-metadata.mjs",
    "sync:i18n": "node scripts/sync-i18n-catalogs.mjs",
    "gen:i18n-review": "node scripts/gen-i18n-review.mjs",
    "gototrack:preflight": "node scripts/gototrack-preflight.mjs",
    "export:web": "npm run prepare:web-metadata && NODE_PATH=./node_modules expo export --platform web",
    "test": "vitest run --config vitest.config.ts",
    "test:full": "npm run test && npm run test:render && npm run typecheck && npm run export:web -- --output-dir /tmp/gogocash-expo-full-test-export",
    "test:flows": "vitest run --config vitest.config.ts src/__tests__/frontend-user-flow-parity.test.ts",
    "test:security": "vitest run --config vitest.config.ts src/__tests__/security-pentest.test.ts",
    "test:render": "vitest run --config vitest.render.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "measure:bundle": "node scripts/measure-web-bundle.mjs",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:maestro": "maestro test .maestro/flows/",
    "build:preview": "eas build --profile preview",
    "build:production": "eas build --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/anuphan": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo/metro-runtime": "~56.0.11",
    "@react-native-community/datetimepicker": "9.1.0",
    "@sentry/react-native": "~8.14.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "5.101.0",
    "expo": "^56.0.0",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.14",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.11",
    "expo-localization": "~56.0.6",
    "expo-modules-core": "~56.0.16",
    "expo-router": "~56.2.5",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "firebase": "^12.14.0",
    "phosphor-react-native": "^3.0.6",
    "posthog-react-native": "4.47.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intl": "^10.1.11",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "14.0.0",
    "@types/node": "^26",
    "@types/react": "latest",
    "babel-preset-expo": "~56.0.0",
    "happy-dom": "^20.9.0",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  }
}
