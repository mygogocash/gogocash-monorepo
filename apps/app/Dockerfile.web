# Minimal static server for the Expo Web export → Cloud Run.
#
# BUILD CONTEXT = apps/app. The Expo Web export (`expo export --platform web`)
# must already exist at apps/app/dist BEFORE this build runs — the GCP rollback
# build path (`.github/workflows/_build-push.yml` for app-web) runs the export
# step first, then builds with:
#   docker build -f apps/app/Dockerfile.web -t <image> apps/app
#
# Serves on Cloud Run's injected $PORT (default 8080). nginx:alpine's entrypoint
# renders /etc/nginx/templates/*.template via envsubst at startup; we scope
# substitution to ${PORT} only so nginx's own $uri/$host vars survive.

FROM nginx:alpine

# Only substitute ${PORT} in templates — leave nginx runtime vars ($uri, $host) alone.
ENV NGINX_ENVSUBST_FILTER=^PORT$
# Default for local `docker run` without -e PORT; Cloud Run overrides at runtime.
ENV PORT=8080

# Static site config (templated; ${PORT} filled at container start).
# Remove the stock default.conf so only our server block is active.
RUN rm -f /etc/nginx/conf.d/default.conf
COPY nginx.conf.template /etc/nginx/templates/default.conf.template

# The exported static bundle.
COPY dist /usr/share/nginx/html

EXPOSE 8080

# nginx:alpine's default CMD runs the envsubst entrypoint then `nginx -g daemon off`.
