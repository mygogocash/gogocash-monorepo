{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "autoIncrement": true,
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.dev.gogocash.co",
        "EXPO_PUBLIC_APP_ENV": "dev",
        "EXPO_PUBLIC_ACCOUNT_DATA_SOURCE": "backend",
        "EXPO_PUBLIC_FRONTEND_URL": "http://localhost:8081",
        "EXPO_PUBLIC_FIREBASE_API_KEY": "$EXPO_PUBLIC_FIREBASE_API_KEY",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "$EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "$EXPO_PUBLIC_FIREBASE_PROJECT_ID",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "$EXPO_PUBLIC_FIREBASE_APP_ID",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview": {
      "autoIncrement": true,
      "channel": "staging",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-staging.gogocash.co",
        "EXPO_PUBLIC_APP_ENV": "staging",
        "EXPO_PUBLIC_ACCOUNT_DATA_SOURCE": "backend",
        "EXPO_PUBLIC_FRONTEND_URL": "https://app-staging.gogocash.co",
        "EXPO_PUBLIC_FIREBASE_API_KEY": "$EXPO_PUBLIC_FIREBASE_API_KEY",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "$EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "$EXPO_PUBLIC_FIREBASE_PROJECT_ID",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "$EXPO_PUBLIC_FIREBASE_APP_ID",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.gogocash.co",
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_ACCOUNT_DATA_SOURCE": "disabled",
        "EXPO_PUBLIC_FRONTEND_URL": "https://app.gogocash.co",
        "EXPO_PUBLIC_FIREBASE_API_KEY": "$EXPO_PUBLIC_FIREBASE_API_KEY",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "$EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "$EXPO_PUBLIC_FIREBASE_PROJECT_ID",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "$EXPO_PUBLIC_FIREBASE_APP_ID"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "SET_VIA_EAS_CREDENTIALS_OR_eas.json_AFTER_APP_STORE_CONNECT_SETUP"
      },
      "android": {
        "track": "internal"
      }
    }
  }
}
