# Dev API (Railway) — default for local Metro + Android dev-client work.
EXPO_PUBLIC_API_URL=https://api.dev.gogocash.co
EXPO_PUBLIC_APP_ENV=dev
# Use "backend" for live admin/API integration; "fixtures" for offline UI parity.
EXPO_PUBLIC_ACCOUNT_DATA_SOURCE=backend
EXPO_PUBLIC_FRONTEND_URL=http://localhost:8081
# Staging alternative: EXPO_PUBLIC_API_URL=https://api-staging.gogocash.co
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Native Google Sign-In (Android/iOS) — leave empty to keep dormant (Coming soon toast).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Native Facebook/Apple sign-in via Firebase's hosted OAuth (RNFB signInWithPopup).
# Comma list to activate per provider (e.g. "facebook" or "facebook,apple");
# empty keeps them dormant (Coming soon toast). Requires the provider enabled
# in the Firebase console with its app id/secret + the firebaseapp.com handler
# whitelisted as the provider's redirect URI.
EXPO_PUBLIC_NATIVE_OAUTH_PROVIDERS=
# LINE Login via LIFF (web / LINE Mini App). Empty keeps the button as Coming soon.
EXPO_PUBLIC_LIFF_ID=
# GoGoPass (membership/subscription) surfaces — default ON when unset; ONLY the
# literal "0" hides them (eas.json pins "0" on the beta profile only).
# EXPO_PUBLIC_ENABLE_GOGOPASS=1
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
EXPO_PUBLIC_SENTRY_DSN=
# EAS Update channels (native OTA) — see eas.json: development | staging | production
# EXPO_PUBLIC_EAS_PROJECT_ID=0039c25f-f88e-491d-8da9-85b8d6e66558
#
# Device acceptance preflight only (not inlined at EAS build):
# GOGOTRACK_AUTH_TOKEN=<customer-jwt>   # fallback: GOTOTRACK_AUTH_TOKEN, GOGOSENSE_AUTH_TOKEN
