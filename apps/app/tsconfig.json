{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "target": "ES2022",
    "types": ["vitest/globals"],
    "paths": {
      "@mobile/*": ["src/*"]
    }
  },
  "include": ["app", "src", "app.config.ts", "vitest.config.ts"],
  "extends": "expo/tsconfig.base"
}
