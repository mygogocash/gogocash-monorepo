{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vitest/globals"],
    // TS 7 removed `baseUrl` (and the 6.0 `ignoreDeprecations` bridge with it);
    // paths entries are now relative to this tsconfig.
    "paths": {
      "@mobile/*": ["./src/*"]
    }
  },
  "include": ["app", "src", "app.config.js", "vitest.config.ts"],
  "extends": "expo/tsconfig.base"
}
