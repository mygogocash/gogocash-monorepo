# Core
PORT=8080
MONGO_URI=mongodb://localhost:27017/gogocash
JWT_SECRET=replace-with-a-long-random-string
JWT_ADMIN_SECRET=replace-with-a-second-random-string

# Involve AI integration (V-5). Shared secret for POST /involve/create-affiliate-ai,
# sent by the external/AI caller as the `x-api-key` header. FAIL-CLOSED: if empty,
# the endpoint rejects every request. Generate via `openssl rand -hex 32`.
INVOLVE_AI_API_KEY=

# Auth + identity
FIREBASE_PROJECT_ID=your-firebase-project-id
CROSSMINT_AUTH_BASE=
CROSSMINT_PROJECT_ID=
CROSSMINT_SECRET=
TELEGRAM_BOT_TOKEN=
WEB_APP_URL=http://localhost:3000
# SIWE/MiniPay domain binding — set to the API host (e.g. api.gogocash.co) to
# enforce EIP-4361 domain+URI checks on /auth/minipay-siwe
SIWE_EXPECTED_DOMAIN=
# Email (Resend) — real RESEND_API_KEY goes to Secret Manager, never here.
# MAIL_FROM must be an address on a Resend-verified domain (gogocash.co).
RESEND_API_KEY=
MAIL_FROM=GoGoCash <noreply@gogocash.co>
# Base URL of the admin app — used to build invite / password-reset email links.
ADMIN_APP_URL=https://admin-staging.gogocash.co
API_BASE_URL=http://localhost:8080

# PostHog product analytics
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ENABLED=true
POSTHOG_DEBUG=false

# Phase 5 — Telegram admin alert groups (reuses existing TELEGRAM_BOT_TOKEN).
TG_OPS_WITHDRAWALS_CHAT_ID=
TG_ALERTS_CHAT_ID=

# Involve Asia
INVOLVE_SECRET=
INVOVLE_SECRET=
INVOVLE_SECRET_OLD=

# Customer billing (server-side Stripe for Expo customer app)
STRIPE_BILLING_ENABLED=false
STRIPE_SECRET_KEY=
CUSTOMER_FRONTEND_URL=https://app.gogocash.co
STRIPE_PRICE_THB_MONTHLY=
STRIPE_PRICE_THB_ANNUAL=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Optimise Media affiliate network
# API key lives in Google Secret Manager (gogocash-{env}-optimise-api-key); do not commit real values.
OPTIMISE_API_KEY=
OPTIMISE_CONTACT_ID=2442123
OPTIMISE_AGENCY_ID=
OPTIMISE_API_BASE=https://api.optimisemedia.com

# Google Drive (brand logos, categories, quest banners — legacy)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# GCS object storage (all admin/customer media uploads)
# Cloud Run uses the service account automatically; for local uploads set
# GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON with storage.objectAdmin.
GCS_CATALOG_BUCKET=gogocash-catalog-staging
GCS_CATALOG_PUBLIC_BASE_URL=
# Optional folder overrides (defaults match code):
# GCS_MEDIA_PREFIX_BANNER_HOME=banner-home
# GCS_MEDIA_PREFIX_BRANDS=brands
# GCS_MEDIA_PREFIX_CATEGORIES=categories
# GCS_MEDIA_PREFIX_QUESTS=quests
# GCS_MEDIA_PREFIX_MISSING_ORDERS=missing-orders
# GCS_MEDIA_PREFIX_WITHDRAW_SLIPS=withdraw-slips
GCS_MAX_UPLOAD_BYTES=10485760
# GCS_MEDIA_UPLOAD_DISABLED=true
# GCS_BANNER_UPLOAD_DISABLED=true     # legacy alias
# GCS_CATALOG_UPLOAD_SIGNING_SECRET=  # catalog signed-upload flow only

# Withdrawal / on-chain
PRIVATE_KEY_WITHDRAW=
CHAIN_ID_WITHDRAW_POLYGON=
CHAIN_ID_WITHDRAW_BNB=
CHAIN_ID_WITHDRAW_SONIC=
CHAIN_ID_WITHDRAW_CELO=
RPC_URL_POLYGON=
RPC_URL_BNB=
RPC_URL_SONIC=
RPC_URL_CELO=
CONTRACT_WITHDRAW_ADDRESS_POLYGON=
CONTRACT_WITHDRAW_ADDRESS_BNB=
CONTRACT_WITHDRAW_ADDRESS_SONIC=
CONTRACT_WITHDRAW_ADDRESS_CELO=
