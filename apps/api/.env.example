# Core
PORT=8080
MONGO_URI=mongodb://localhost:27017/gogocash
JWT_SECRET=replace-with-a-long-random-string
JWT_ADMIN_SECRET=replace-with-a-second-random-string

# Involve AI integration (V-5). Shared secret for POST /involve/create-affiliate-ai,
# sent by the external/AI caller as the `x-api-key` header. FAIL-CLOSED: if empty,
# the endpoint rejects every request. Generate via `openssl rand -hex 32`.
INVOLVE_AI_API_KEY=

# Auth + identity
FIREBASE_PROJECT_ID=your-firebase-project-id
# Numeric LINE Login channel id used to bind verified access tokens to this app.
# For the staging LIFF id 2008237916-KY5oR5mW, this is 2008237916.
LINE_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
WEB_APP_URL=http://localhost:3000
# SIWE/MiniPay domain binding — set to the API host (e.g. api.gogocash.co) to
# enforce EIP-4361 domain+URI checks on /auth/minipay-siwe
SIWE_EXPECTED_DOMAIN=
# Email (Resend) — real RESEND_API_KEY goes to Secret Manager, never here.
# MAIL_FROM must be an address on a Resend-verified domain (gogocash.co).
RESEND_API_KEY=
MAIL_FROM=GoGoCash <noreply@gogocash.co>
# Base URL of the admin app — used to build invite / password-reset email links.
ADMIN_APP_URL=https://admin-staging.gogocash.co
API_BASE_URL=http://localhost:8080

# PostHog product analytics
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ENABLED=true
POSTHOG_DEBUG=false

# Phase 5 — Telegram admin alert groups (reuses existing TELEGRAM_BOT_TOKEN).
TG_OPS_WITHDRAWALS_CHAT_ID=
TG_ALERTS_CHAT_ID=

# Involve Asia
INVOLVE_SECRET=
INVOVLE_SECRET=
INVOVLE_SECRET_OLD=
# Involve GET postback shared secret (`token` query param on GET /involve/postback).
# FAIL-CLOSED: if empty, postbacks are rejected. Generate via `openssl rand -hex 32`.
INVOLVE_POSTBACK_SECRET=

# Customer billing (server-side Stripe for Expo customer app)
STRIPE_BILLING_ENABLED=false
STRIPE_SECRET_KEY=
CUSTOMER_FRONTEND_URL=https://app.gogocash.co
STRIPE_PRICE_THB_MONTHLY=
STRIPE_PRICE_THB_ANNUAL=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Optimise Media affiliate network
# API key lives in Google Secret Manager (gogocash-{env}-optimise-api-key); do not commit real values.
OPTIMISE_API_KEY=
OPTIMISE_CONTACT_ID=2442123
OPTIMISE_AGENCY_ID=
OPTIMISE_API_BASE=https://api.optimisemedia.com

# Accesstrade affiliate network
# Value = the numeric tail of the Accesstrade datafeed API link. Used only for
# the admin "connected" flag until the Accesstrade provider adapter lands.
ACCESSTRADE_API_KEY=

# Google Drive (brand logos, categories, quest banners — legacy)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# Cloudflare R2 object storage (all admin/customer media uploads)
R2_BUCKET=gogocash-catalog-staging
R2_ENDPOINT=https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://media-staging.gogocash.co
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# R2_REGION=auto
MEDIA_MAX_UPLOAD_BYTES=10485760
# MEDIA_UPLOAD_DISABLED=true
# MEDIA_UPLOAD_SIGNING_SECRET=  # catalog signed-upload flow only
# Optional local dev disk store for legacy local-media: refs in Mongo
# MEDIA_LOCAL_STORAGE_DIR=.local-media
# Optional folder overrides (defaults match code; GCS_MEDIA_PREFIX_* still honored):
# MEDIA_PREFIX_BANNER_HOME=banner-home
# MEDIA_PREFIX_BRANDS=brands

# Withdrawal / on-chain
PRIVATE_KEY_WITHDRAW=
CHAIN_ID_WITHDRAW_POLYGON=
CHAIN_ID_WITHDRAW_BNB=
CHAIN_ID_WITHDRAW_SONIC=
CHAIN_ID_WITHDRAW_CELO=
RPC_URL_POLYGON=
RPC_URL_BNB=
RPC_URL_SONIC=
RPC_URL_CELO=
CONTRACT_WITHDRAW_ADDRESS_POLYGON=
CONTRACT_WITHDRAW_ADDRESS_BNB=
CONTRACT_WITHDRAW_ADDRESS_SONIC=
CONTRACT_WITHDRAW_ADDRESS_CELO=
