{
  "name": "gogocash-api",
  "version": "0.0.1",
  "description": "GoGoCash backend API built with NestJS",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "swc src -d dist --strip-leading-paths",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node -r @swc-node/register src/main.ts",
    "start:dev": "node --watch -r @swc-node/register src/main.ts",
    "start:debug": "node --watch --inspect -r @swc-node/register src/main.ts",
    "start:prod": "node dist/main",
    "lint": "oxlint --fix src test scripts && prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:ci": "oxlint --deny-warnings src test scripts && prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r @swc-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate:brands": "node -r @swc-node/register scripts/migrate-brands.ts",
    "migrate:brands:dry": "node -r @swc-node/register scripts/migrate-brands.ts --dry-run",
    "migrate:country": "node -r @swc-node/register scripts/migrate-country.ts",
    "migrate:country:dry": "node -r @swc-node/register scripts/migrate-country.ts --dry-run",
    "backfill:conversion-userid": "node -r @swc-node/register scripts/backfill-conversion-userid.ts",
    "backfill:conversion-userid:dry": "node -r @swc-node/register scripts/backfill-conversion-userid.ts --dry-run",
    "backfill:offer-source": "node -r @swc-node/register scripts/backfill-offer-source.ts",
    "backfill:offer-source:dry": "node -r @swc-node/register scripts/backfill-offer-source.ts --dry-run",
    "backfill:quest-tasks": "node -r @swc-node/register scripts/backfill-quest-tasks.ts",
    "backfill:quest-tasks:dry": "node -r @swc-node/register scripts/backfill-quest-tasks.ts --dry-run",
    "gototrack:seed-merchants": "node -r @swc-node/register scripts/seed-gototrack-merchants.ts",
    "seed:local-admin": "node -r @swc-node/register scripts/seed-local-admin.ts",
    "seed:local-customer": "node -r @swc-node/register scripts/seed-local-customer.ts",
    "seed:e2e-fixtures": "node -r @swc-node/register scripts/seed-e2e-fixtures.ts",
    "seed:e2e": "node -r @swc-node/register scripts/seed-e2e.ts",
    "seed:top-brands": "node -r @swc-node/register scripts/seed-top-brands.ts",
    "seed:top-brands:dry": "node -r @swc-node/register scripts/seed-top-brands.ts --dry-run",
    "media:inventory": "node -r @swc-node/register scripts/inventory-stored-media.ts",
    "media:migrate-gcs-to-r2": "node -r @swc-node/register scripts/migrate-stored-media-gcs-to-r2.ts",
    "media:migrate-gcs-to-r2:dry": "node -r @swc-node/register scripts/migrate-stored-media-gcs-to-r2.ts --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.4.5",
    "@posthog/core": "^1.40.2",
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.2.0",
    "@types/passport-jwt": "^4.0.1",
    "archiver": "^7.0.1",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "ethers": "^6.17.0",
    "express": "^5.1.0",
    "firebase-admin": "^14.1.0",
    "googleapis": "^173.0.0",
    "helmet": "^8.3.0",
    "jwks-rsa": "^4.1.0",
    "mime-types": "^3.0.1",
    "mongodb": "^7.4.0",
    "mongoose": "^9.7.4",
    "multer": "^2.2.0",
    "nestjs-telegraf": "^2.9.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "posthog-node": "^5.41.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.17.1",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.3",
    "stripe": "^22.3.1",
    "swagger-ui-express": "^5.0.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@nestjs/config": "^4.0.2",
    "@nestjs/testing": "^11.1.28",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/archiver": "^6.0.4",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/supertest": "^7.2.1",
    "jest": "^30.0.0",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "typescript": "^7.0.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "@swc/jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(jose|jwks-rsa)/)"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
