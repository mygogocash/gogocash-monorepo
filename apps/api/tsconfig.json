{
  "compilerOptions": {
    // TS 7 removed node10 resolution (the old commonjs default). node16 is the
    // faithful replacement for this CJS Nest app: no package.json "type" field →
    // every file stays CJS, emit is unchanged, and dependency types resolve via
    // the "require" exports condition — matching what Node does at runtime.
    "module": "node16",
    "moduleResolution": "node16",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    // Pin esModuleInterop ON explicitly (it's TS 6.0's default, but make it
    // version-independent): the default imports of CJS callables (cookie-parser,
    // supertest) only emit the __importDefault helper — and stay callable at
    // runtime — when this is true. Without it, a build that happened to transpile
    // under TS 5.9 (esModuleInterop:false) would emit require("cookie-parser").default
    // (undefined) and crash `app.use(cookieParser())` in the boot smoke.
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    // TS 7 removed `baseUrl`; the bare `src/...` specifiers used across the app
    // now resolve via an explicit paths mapping (values must be relative).
    // Runtime/emit resolution of the same alias: .swcrc (build + jest) and the
    // jest moduleNameMapper — keep the three in sync.
    "paths": {
      "src/*": ["./src/*"]
    },
    // TS 6.0 flipped several defaults; TS 7.0 then hard-removed `baseUrl` and
    // the `ignoreDeprecations:"6.0"` bridge (both deleted above). The remaining
    // pins preserve the TS 5.9 behavior this project was written under (see
    // UPGRADE_PLAN Tier 1 #2):
    //  - strict:false  — 6.0 defaults strict:true, which would newly enable
    //    strictPropertyInitialization (breaks Mongoose @Prop fields) and
    //    useUnknownInCatchVariables (breaks every catch(e)). Keep it off here;
    //    tightening strictness is a separate, intentional effort.
    //  - types — 6.0 dropped auto-include of node_modules/@types, so every
    //    package contributing GLOBAL ambients/augmentations must be listed:
    //    node (process/Buffer), jest (describe/it/expect), express (the base
    //    global Express namespace), multer (Express.Multer.File — used in the
    //    upload controllers), passport (Express.Request.user). Modules that are
    //    imported by name don't need listing; only globals do.
    "strict": false,
    "types": ["node", "jest", "express", "multer", "passport"],
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false
  }
}
