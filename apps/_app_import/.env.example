# Copy to .env.local and fill in values. Never commit real secrets.
# CI may set SKIP_ENV_VALIDATION=1 for builds without full env.
#
# --- Rules ---
# - Never use NEXT_PUBLIC_* for secrets (they are embedded in the browser bundle).
# - Rotate any secret that was pasted into chat, tickets, or committed by mistake.

# --- Server (NextAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- Server — OAuth (optional; use for server-side flows, not for Firebase popup login) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Server — Meta / Facebook ---
# App Secret from developers.facebook.com — NEVER NEXT_PUBLIC_FACEBOOK_* for this value.
# FACEBOOK_APP_SECRET=

# --- Server — Telegram ---
# Full bot token for webhooks / backend verification only (not required for Login OAuth URL).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=

# --- Public API ---
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_FRONTEND_URL=
# When 1/true/yes, use in-app mock API (src/mocks/homeApi.ts) even if NEXT_PUBLIC_API_URL is set.
# Optional: pick mock profile — mock-user-001 … mock-user-005 (see src/mocks/homeApi.ts).
# NEXT_PUBLIC_MOCK_API=1
# NEXT_PUBLIC_MOCK_ACTIVE_USER_ID=mock-user-001
# With mock API: optional huge catalog for Product Discovery (procedural offers, paginated).
# NEXT_PUBLIC_MOCK_OFFER_CATALOG_SIZE=10000

# --- Brandfetch (optional merchant hero mock / enrichment) ---
# Server-only Brand API key: https://developers.brandfetch.com — never commit real keys.
BRANDFETCH_API_KEY=
# When 1 or true, shop hero prefers Brandfetch banner & logo when URLs exist (else fills only missing).
NEXT_PUBLIC_BRANDFETCH_HERO=

# --- Firebase (client) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Telegram login (client) ---
# Numeric bot id for oauth.telegram.org (digits only — same as the part before ":" in the bot token).
# Required for Telegram OAuth. The legacy NEXT_PUBLIC_TELEGRAM_BOT_TOKEN
# fallback was removed because it shipped the full bot secret to the browser
# bundle. NEVER expose the full Telegram bot token via any NEXT_PUBLIC_* var.
NEXT_PUBLIC_TELEGRAM_BOT_ID=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# --- Analytics ---
NEXT_PUBLIC_ANALYTICS_ENABLED=
NEXT_PUBLIC_ANALYTICS_DEBUG=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
# Facebook App ID only (public).
NEXT_PUBLIC_FACEBOOK_CLIENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
# Floating “Cookies” control to reopen the PDPA banner (staging/QA). Omitted in production; always on in `next dev`.
# NEXT_PUBLIC_INTERNAL_CONSENT_BANNER_BUTTON=1

# --- Web3 withdraw ---
NEXT_PUBLIC_CHAIN_ID_WITHDRAW_SONIC=
NEXT_PUBLIC_CHAIN_ID_WITHDRAW_POLYGON=
NEXT_PUBLIC_CHAIN_ID_WITHDRAW_BNB=
NEXT_PUBLIC_CHAIN_ID_WITHDRAW_CELO=
NEXT_PUBLIC_CONTRACT_WITHDRAW_ADDRESS_POLYGON=
NEXT_PUBLIC_CONTRACT_WITHDRAW_ADDRESS_BNB=
NEXT_PUBLIC_CONTRACT_WITHDRAW_ADDRESS_SONIC=
NEXT_PUBLIC_CONTRACT_WITHDRAW_ADDRESS_CELO=

# --- Observability / Sentry (optional) ---
# Client (browser) DSN — also used as fallback for server/edge if SENTRY_DSN is unset.
NEXT_PUBLIC_SENTRY_DSN=
# Server-only DSN (optional; preferred for server/edge per Sentry docs).
SENTRY_DSN=
# Production source maps + releases (build/CI). Create at https://sentry.io/settings/auth-tokens/
# Scopes: project:releases, org:read. Can use a local file — see https://docs.sentry.io/platforms/javascript/guides/nextjs/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional: put the token in this file (gitignored via .env*) instead of .env.local
# .env.sentry-build-plugin

# --- Category policy (Phase 3 of docs/POLICY_MULTILANG_PLAN.md) ---
# When 1/true/yes, render the admin-authored Terms & Conditions section
# on /category/[name]. Off by default so the Admin (Phase 2) ships first
# and admins can populate translations before customers see them.
NEXT_PUBLIC_CATEGORY_POLICY_TERMS=

# --- Stripe (optional — Go Unlimited / membership checkout) ---
# Set NEXT_PUBLIC_STRIPE_BILLING=1 to enable checkout UI on /membership.
NEXT_PUBLIC_STRIPE_BILLING=
# Publishable key only if you add Stripe.js / Elements later (server routes do not require it).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret key (server-only). Use test keys in development.
STRIPE_SECRET_KEY=
# Webhook signing secret from Stripe Dashboard → Developers → Webhooks → endpoint.
# Forward local events: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# Local THB flow: set STRIPE_PRICE_THB_* from Dashboard, run `pnpm dev`, open /th/pricing, pay with 4242…4242.
STRIPE_WEBHOOK_SECRET=
# THB GoGo Unlimited (preferred). Create products in Stripe test mode with currency THB: 49 / month, 490 / year.
STRIPE_PRICE_THB_MONTHLY=
STRIPE_PRICE_THB_ANNUAL=
# Legacy Price IDs (still supported if THB vars unset — must match currency in Dashboard).
STRIPE_PRICE_STARTER_MONTHLY=
# Annual Starter for /pricing — same as STRIPE_PRICE_STARTER_YEARLY if you only use one env name.
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
