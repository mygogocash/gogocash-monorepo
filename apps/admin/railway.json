{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/admin/Dockerfile",
    "watchPatterns": [
      "apps/admin/**",
      "package.json",
      "package-lock.json",
      "apps/admin/railway.json"
    ]
  },
  "deploy": {
    "startCommand": "node /app/apps/admin/server.js",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
