# ─── Internal use only ───
# This app is configured to use mock data only (no real API).
# All data is served from /api/mock. Sign-in: admin@gogocash.co / 1234

# NextAuth secret used for JWT/session encryption
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Server-only: allow mock password 1234 (NextAuth + /api/mock) outside development.
# Default off in production Node builds. Firebase static builds use NEXT_PUBLIC_FIREBASE_STATIC instead.
# ALLOW_MOCK_ADMIN_PASSWORD=true

# Must match the URL you open in the browser (port = dev server port).
# Default `npm run dev` → 3000. Use `npm run dev:3001` → set to http://localhost:3001
NEXTAUTH_URL=http://localhost:3000

# Customer app base URL for admin preview/deeplink buttons.
NEXT_PUBLIC_APP_URL=http://localhost:19006

# Local development defaults
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Optional: extra hostnames for next/image optimization (comma-separated, no protocol)
# Must match your CDN or API file URLs. See docs/RUNBOOK.md.
# NEXT_PUBLIC_IMAGE_OPT_HOSTS=cdn.example.com,files.example.com

# ─── Firebase Hosting (staging / internal review) ───
# Build: `npm run build:firebase` sets BUILD_FOR_FIREBASE=1 and NEXT_PUBLIC_FIREBASE_STATIC=1
# (do not set manually). Static Hosting has no API routes; the client runs the same mock logic in-browser.
# Before `npm run deploy:firebase` or `npm run deploy:firebase:staging`, set:
#   NEXTAUTH_SECRET — same as above; use a dedicated secret per environment.
#   NEXTAUTH_URL — exact HTTPS URL of the hosted site (no trailing slash), e.g.
#     https://gogocash-staging-637d5.web.app
# GitHub Actions: store as secrets NEXTAUTH_SECRET_STAGING and NEXTAUTH_URL_STAGING.
# See docs/FIREBASE_STAGING_INTERNAL_REVIEW.md and .github/workflows/firebase-hosting-staging.yml.

# ─── Production (gogocash_admin @ admin.gogocash.co) ───
# Set on the hosting provider / CI (do not commit secrets). Typical values:
#   NEXT_PUBLIC_API_URL=https://api.gogocash.co
#   NEXTAUTH_URL=https://admin.gogocash.co
#   NEXTAUTH_SECRET=<openssl rand -base64 32>  — one value per environment; never commit
#
# Optional locally: uncomment to point asset URLs at the real API while developing.
# NEXT_PUBLIC_API_URL=https://api.gogocash.co
