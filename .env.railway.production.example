# .env.railway.production.example
#
# Template for scripts/railway-apply-secrets.sh. Copy to .env.railway.production
# (gitignored via the `.env.*` rule) and fill in REAL values. Leave a line blank
# / unset to skip that variable (the script skips empty values).
#
#   cp .env.railway.production.example .env.railway.production
#   ./scripts/railway-apply-secrets.sh --dry-run   # shows KEY -> service, no values
#   ./scripts/railway-apply-secrets.sh             # applies
#
# Generate fresh secrets:
#   openssl rand -hex 32      # JWT_SECRET / JWT_ADMIN_SECRET / INVOLVE_POSTBACK_SECRET
#   openssl rand -base64 32   # NEXTAUTH_SECRET
#
# NOTE: non-secret API config (NODE_ENV, MAIL_FROM, POSTHOG_HOST/ENABLED,
# GCS_CATALOG_BUCKET, *_URL staging values, STRIPE_BILLING_ENABLED=false, etc.)
# is ALREADY applied on Railway — see docs/railway-env-matrix.md. Do not re-add
# it here unless you are overriding a value.

# ===== gogocash-api =====
# Point at external Atlas staging (or keep Railway Mongo — see runbook Step 1)
MONGO_URI=
# minimal-to-usable
JWT_SECRET=
JWT_ADMIN_SECRET=
# full functionality (feature-gated)
FIREBASE_PROJECT_ID=
# transition window only: old project so not-yet-updated builds keep working
FIREBASE_SECONDARY_PROJECT_ID=
INVOLVE_SECRET=
INVOLVE_POSTBACK_SECRET=
INVOLVE_AI_API_KEY=
RESEND_API_KEY=
POSTHOG_KEY=
# Login Widget verifier only. Leave unset until the browser rollout is
# explicitly approved; this remains a fully privileged BotFather token.
TELEGRAM_LOGIN_BOT_TOKEN=
# Poller + Mini App owner only. Exactly one API instance may set this.
TELEGRAM_BOT_TOKEN=
OPTIMISE_API_KEY=
# exact-match CORS origins for browser calls (comma-separated, no wildcards)
CORS_EXTRA_ORIGINS=https://admin-staging.gogocash.co,https://app-staging.gogocash.co,https://gogocash-admin-production.up.railway.app,https://gogocash-api-production.up.railway.app

# Media — optional (see docs/railway-execution-runbook.md Step 4)
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Cloudflare R2 (required for gogocash-api media uploads)
R2_BUCKET=gogocash-catalog-staging
R2_ENDPOINT=https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://media-staging.gogocash.co
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ===== gogocash-admin =====
# Values below are the STAGING template. For Railway production (beta) use:
#   NEXT_PUBLIC_API_URL=https://api-beta.gogocash.co
#   NEXTAUTH_URL=https://admin-beta.gogocash.co
#   API_URL=http://gogocash-api.railway.internal:8080   # same private host
# BUILD-TIME (rebuild on change). Must be the API's public HTTPS origin.
NEXT_PUBLIC_API_URL=https://api-staging.gogocash.co
# RUNTIME — Nest upstream for /api/backend/* (private Railway DNS; do NOT use
# *.up.railway.app, api-*.gogocash.co, or RAILWAY_SERVICE_*_URL — see #407).
API_URL=http://gogocash-api.railway.internal:8080
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://admin-staging.gogocash.co

# ===== app-web (@gogocash/mobile) — ALL build-time (rebuild on change) =====
EXPO_PUBLIC_API_URL=https://api-staging.gogocash.co
EXPO_PUBLIC_APP_ENV=staging
EXPO_PUBLIC_ACCOUNT_DATA_SOURCE=backend
EXPO_PUBLIC_FRONTEND_URL=https://app-staging.gogocash.co
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# optional
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_EAS_PROJECT_ID=
