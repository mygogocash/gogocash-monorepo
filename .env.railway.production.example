# Railway staging cutover — copy to .env.railway.production (gitignored).
# Apply with: ./scripts/railway-apply-secrets.sh [--dry-run]
#
# Generate secrets:
#   openssl rand -hex 32      # JWT_SECRET, JWT_ADMIN_SECRET, INVOLVE_POSTBACK_SECRET
#   openssl rand -base64 32   # NEXTAUTH_SECRET
#
# Minimum to boot with real data: MONGO_URI + JWT_* + CROSSMINT_SECRET (api) + NEXTAUTH_SECRET (admin).

# ─── gogocash-api ────────────────────────────────────────────────────────────
MONGO_URI=
JWT_SECRET=
JWT_ADMIN_SECRET=
FIREBASE_PROJECT_ID=
INVOLVE_SECRET=
INVOLVE_POSTBACK_SECRET=
INVOLVE_AI_API_KEY=
POSTHOG_KEY=
TELEGRAM_BOT_TOKEN=
CROSSMINT_AUTH_BASE=
CROSSMINT_PROJECT_ID=
CROSSMINT_SECRET=
RESEND_API_KEY=
OPTIMISE_API_KEY=

# Non-secret API config (safe to commit defaults in runbook; override if needed)
API_BASE_URL=https://api-staging.gogocash.co
ADMIN_APP_URL=https://admin-staging.gogocash.co
WEB_APP_URL=https://app-staging.gogocash.co
CUSTOMER_FRONTEND_URL=https://app-staging.gogocash.co
GCS_CATALOG_BUCKET=gogocash-catalog-staging
GCS_MAX_UPLOAD_BYTES=10485760
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ENABLED=true
POSTHOG_DEBUG=false
STRIPE_BILLING_ENABLED=false
OPTIMISE_CONTACT_ID=2442123
OPTIMISE_API_BASE=https://api.optimisemedia.com
MAIL_FROM=GoGoCash <noreply@gogocash.co>

# Media — pick ONE path:
# A) Keep GCS: set GOOGLE_APPLICATION_CREDENTIALS_JSON (full service-account JSON, one line)
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
# B) Cloudflare R2 (requires API R2 driver — see docs/railway-execution-runbook.md Step 4)
# MEDIA_STORAGE_DRIVER=r2
# R2_BUCKET=gogocash-catalog-staging
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://<public-r2-base>
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# ─── gogocash-admin ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://admin-staging.gogocash.co
NEXT_PUBLIC_API_URL=https://api-staging.gogocash.co
NEXT_PUBLIC_APP_URL=https://app-staging.gogocash.co

# ─── @gogocash/mobile (Expo web static) ──────────────────────────────────────
EXPO_PUBLIC_API_URL=https://api-staging.gogocash.co
EXPO_PUBLIC_APP_ENV=staging
EXPO_PUBLIC_ACCOUNT_DATA_SOURCE=backend
EXPO_PUBLIC_FRONTEND_URL=https://app-staging.gogocash.co
