{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [".agents/**", ".cursor/**", "skills-lock.json", "e2e/**"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreBinaries": ["eas", "knip", "maestro"],
  "ignoreUnresolved": ["dotenv/config", "expo-system-ui"],
  "ignoreDependencies": [
    "@nestjs/common",
    "@nestjs/core",
    "reflect-metadata",
    "rxjs",
    "@fullcalendar/list",
    "@react-jvectormap/core",
    "@react-jvectormap/world",
    "@tailwindcss/forms",
    "@tanstack/query-sync-storage-persister",
    "@tanstack/react-query-persist-client",
    "autoprefixer",
    "firebase",
    "react-dnd",
    "react-dnd-html5-backend",
    "swiper",
    "@crossmint/server-sdk",
    "@nestjs/passport",
    "@posthog/core",
    "@types/passport-jwt",
    "jwks-rsa",
    "mime-types",
    "mongodb",
    "passport-jwt",
    "swagger-ui-express",
    "expo-modules-core",
    "@svgr/webpack",
    "@types/react-transition-group",
    "tailwindcss",
    "source-map-support",
    "ts-loader",
    "babel-preset-expo",
    "react-test-renderer",
    "@nestjs/platform-express",
    "mongoose"
  ],
  "ignoreIssues": {
    "apps/admin/src/lib/api.ts": ["duplicates"],
    "apps/admin/src/types/**": ["exports", "enumMembers", "types"],
    "apps/admin/src/data/executive/**": ["exports"],
    "apps/admin/src/icons/index.tsx": ["exports"],
    "apps/admin/src/layout/**": ["exports"],
    "apps/admin/src/lib/**": ["exports"],
    "apps/admin/src/config/**": ["exports"],
    "apps/admin/src/data/mockPendingOffers.ts": ["exports"],
    "apps/admin/src/utils/**": ["exports"],
    "apps/api/src/**/schemas/*.schema.ts": ["exports", "types"],
    "apps/api/src/**/dto/**": ["exports", "types"],
    "apps/api/scripts/**": ["unlisted"],
    "apps/app/app.config.ts": ["unlisted"],
    "apps/admin/src/lib/policyPayload.ts": ["types"],
    "apps/api/src/media/local-object-storage.ts": ["exports"]
  },
  "workspaces": {
    "apps/api": {
      "entry": ["src/main.ts", "scripts/*.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "scripts/**/*.ts"],
      "ignore": ["dist/**"]
    },
    "apps/app": {
      "entry": ["expo-router/entry", "app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}", "app/**/*.{ts,tsx}", "scripts/**/*.{mjs,js}"],
      "ignore": [
        "babel.config.js",
        "playwright.config.ts",
        "e2e/**",
        "plugins/**",
        "src/test-support/**",
        "scripts/migrate-themed-styles.mjs",
        "scripts/themedify-colors.mjs"
      ]
    },
    "apps/admin": {
      "entry": ["src/app/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
