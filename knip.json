{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    ".agents/**",
    ".cursor/**",
    "skills-lock.json",
    "e2e/**",
    "scripts/figma-brand-logos/**",
    "scripts/firebase-staging-auth-setup.mjs"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreBinaries": [
    "eas",
    "maestro",
    "gcloud"
  ],
  "ignoreUnresolved": [
    "dotenv/config"
  ],
  "ignoreDependencies": [
    "@nestjs/common",
    "@nestjs/core",
    "reflect-metadata",
    "rxjs",
    "@fullcalendar/list",
    "@react-jvectormap/core",
    "@react-jvectormap/world",
    "@tailwindcss/forms",
    "@tanstack/query-sync-storage-persister",
    "@tanstack/react-query-persist-client",
    "autoprefixer",
    "firebase",
    "react-dnd",
    "react-dnd-html5-backend",
    "swiper",
    "@nestjs/passport",
    "@posthog/core",
    "@types/passport-jwt",
    "jwks-rsa",
    "mime-types",
    "mongodb",
    "passport-jwt",
    "swagger-ui-express",
    "expo-modules-core",
    "@svgr/webpack",
    "@types/react-transition-group",
    "tailwindcss",
    "source-map-support",
    "babel-preset-expo",
    "react-test-renderer",
    "react-native-screens",
    "@nestjs/platform-express",
    "mongoose",
    "happy-dom",
    "typescript-eslint",
    "@mui/material",
    "@mui/system",
    "cache-manager",
    "@swc/core"
  ],
  "ignoreIssues": {
    "apps/admin/src/lib/api.ts": [
      "duplicates"
    ],
    "apps/admin/src/types/**": [
      "exports",
      "enumMembers",
      "types"
    ],
    "apps/admin/src/data/executive/**": [
      "exports"
    ],
    "apps/admin/src/icons/index.tsx": [
      "exports"
    ],
    "apps/admin/src/layout/**": [
      "exports"
    ],
    "apps/admin/src/lib/**": [
      "exports"
    ],
    "apps/admin/src/config/**": [
      "exports"
    ],
    "apps/admin/src/data/mockPendingOffers.ts": [
      "exports"
    ],
    "apps/admin/src/utils/**": [
      "exports"
    ],
    "apps/api/src/**/schemas/*.schema.ts": [
      "exports",
      "types"
    ],
    "apps/api/src/**/dto/**": [
      "exports",
      "types"
    ],
    "apps/api/scripts/**": [
      "unlisted"
    ],
    "apps/app/app.config.js": [
      "unlisted"
    ],
    "apps/admin/src/lib/policyPayload.ts": [
      "types"
    ],
    "apps/api/src/media/local-object-storage.ts": [
      "exports"
    ],
    "apps/app/src/config/featureFlags.ts": [
      "duplicates"
    ],
    "apps/app/src/api/optimizedImageUrl.ts": [
      "duplicates"
    ],
    "apps/api/src/auth/firebase-admin.provider.ts": [
      "exports"
    ]
  },
  "workspaces": {
    ".": {
      "entry": [
        "scripts/deployment/*.mjs",
        "scripts/reconcile-affiliate-mint-reservations.cjs",
        "scripts/staging-coupon-qa-evidence.cjs",
        "scripts/staging-coupon-qa-mongo.cjs"
      ],
      "project": [
        "scripts/**/*.{js,mjs,cjs}"
      ]
    },
    "apps/api": {
      "entry": [
        "src/main.ts",
        "scripts/*.ts",
        "test/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts",
        "scripts/**/*.ts"
      ],
      "ignore": [
        "dist/**"
      ]
    },
    "apps/app": {
      "entry": [
        "expo-router/entry",
        "app/**/*.{ts,tsx}",
        "src/**/*.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "app/**/*.{ts,tsx}",
        "scripts/**/*.{mjs,js}"
      ],
      "ignore": [
        "babel.config.js",
        "playwright.config.ts",
        "e2e/**",
        "plugins/**",
        "src/test-support/**",
        "scripts/migrate-themed-styles.mjs",
        "scripts/themedify-colors.mjs"
      ]
    },
    "apps/admin": {
      "entry": [
        "src/app/**/*.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "packages/gototrack-mcp": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/contracts": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    }
  }
}
