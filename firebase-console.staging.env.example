# Copy keys into Firebase Console → App Hosting → gogocash-web → Environment
# (or set equivalent entries in apphosting.yaml). Do not commit real values.
#
# For NEXTAUTH_SECRET use Secret Manager instead of a plain env value:
#   npx firebase apphosting:secrets:set NEXTAUTH_SECRET
# Then add the parameter in console as a secret reference, or uncomment the
# secret block in apphosting.yaml (see file comments).
#
# NEXT_PUBLIC_* must be available at BUILD and RUNTIME.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=gogocash-app-staging
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: real staging API (turn off mock in console — unset NEXT_PUBLIC_MOCK_API or set 0)
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_MOCK_API=0
