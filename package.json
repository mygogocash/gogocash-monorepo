{
  "name": "gogocash-web",
  "version": "0.1.0",
  "description": "GoGoCash customer-facing web app built with Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{ts,mjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{ts,mjs,json,md}\"",
    "test": "vitest run",
    "validate": "npm run lint && npm run format:check && npm run test",
    "generate:shop-menu-tap-paths": "node scripts/generate-shop-menu-tap-paths.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "ANALYZE=true next build",
    "perf:bundle-note": "node scripts/perf-bundle-note.mjs",
    "perf:baseline": "node scripts/perf-baseline.mjs",
    "perf:check-budget": "node scripts/check-bundle-budget.mjs"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@crossmint/client-sdk-react-ui": "^1.19.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-data-grid": "^8.28.1",
    "@sentry/nextjs": "^10.46.0",
    "@tanstack/query-sync-storage-persister": "^5.90.10",
    "@tanstack/react-query": "^5.90.8",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-query-persist-client": "^5.90.10",
    "@types/next-auth": "^3.15.0",
    "axios": "^1.13.2",
    "ethers": "^6.15.0",
    "firebase": "^12.6.0",
    "libphonenumber-js": "^1.12.31",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "next-intl": "^4.5.5",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-error-boundary": "^6.0.0",
    "react-hot-toast": "^2.6.0",
    "swiper": "^12.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.0.1",
    "@playwright/test": "^1.58.2",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.1",
    "happy-dom": "^20.8.9",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "resolutions": {
    "react-is": "^18.3.1"
  }
}
