{
  "name": "gogocash-web",
  "version": "0.1.0",
  "description": "GoGoCash customer-facing web app built with Next.js",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 next build --webpack",
    "postbuild": "node scripts/sync-next-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{ts,mjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{ts,mjs,json,md}\"",
    "test": "vitest run",
    "i18n:check": "node scripts/check-i18n-messages.mjs",
    "validate": "npm run lint && npm run format:check && npm run i18n:check && npm run test",
    "generate:shop-menu-tap-paths": "node scripts/generate-shop-menu-tap-paths.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "NODE_OPTIONS=--max-old-space-size=8192 ANALYZE=true next build --webpack",
    "perf:bundle-note": "node scripts/perf-bundle-note.mjs",
    "perf:baseline": "node scripts/perf-baseline.mjs",
    "perf:check-budget": "node scripts/check-bundle-budget.mjs",
    "deploy:firebase": "firebase deploy --only apphosting:gogocash-web",
    "deploy:firebase:preflight": "node scripts/firebase-deploy-preflight.mjs",
    "deploy:firebase:release": "npm run validate && npm run build && npm run deploy:firebase:preflight && npm run deploy:firebase",
    "apphosting:delete-stale-build": "node scripts/apphosting-delete-build.mjs"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@mui/x-data-grid": "^8.28.2",
    "@mui/x-date-pickers": "^9.0.0",
    "@sentry/nextjs": "^10.48.0",
    "@tanstack/query-sync-storage-persister": "^5.97.0",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.97.0",
    "@tanstack/react-query-persist-client": "^5.97.0",
    "axios": "^1.15.0",
    "dayjs": "^1.11.20",
    "ethers": "^6.16.0",
    "firebase": "^12.12.0",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "next-intl": "^4.9.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.1.1",
    "react-hot-toast": "^2.6.0",
    "stripe": "^22.0.1",
    "swiper": "^12.0.3",
    "tailwind-merge": "^3.4.0",
    "viem": "^2.48.1",
    "wagmi": "^2.19.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.3",
    "@playwright/test": "^1.59.1",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/eslint-plugin-query": "^5.97.0",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.1",
    "firebase-tools": "^14.0.0",
    "google-auth-library": "^9.15.1",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "react-is": "^18.3.1",
    "fast-xml-parser": "^5.5.9"
  }
}
