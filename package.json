{
  "name": "gogocash-admin",
  "version": "2.0.2",
  "description": "GoGoCash internal admin dashboard built with Next.js",
  "private": true,
  "packageManager": "npm@10.9.0",
  "scripts": {
    "dev": "next dev",
    "dev:3001": "next dev -p 3001",
    "setup:local": "node scripts/setup-local-env.mjs",
    "check:conflicts": "node scripts/check-merge-conflicts.mjs",
    "prebuild": "node scripts/check-merge-conflicts.mjs",
    "build": "next build",
    "build:standalone": "cross-env STANDALONE=1 next build",
    "start": "next start",
    "lint": "eslint .",
    "analyze": "cross-env ANALYZE=true next build",
    "deploy": "vercel deploy --prod",
    "deploy:preview": "vercel deploy",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "build:firebase": "cross-env BUILD_FOR_FIREBASE=1 NEXT_PUBLIC_FIREBASE_STATIC=1 next build",
    "deploy:firebase": "npm run build:firebase && firebase deploy",
    "deploy:firebase:staging": "node scripts/deploy-firebase-staging.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/list": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.15",
    "@mui/material": "^7.3.5",
    "@mui/system": "^7.3.5",
    "@mui/x-data-grid": "^8.24.0",
    "@opennextjs/cloudflare": "^1.18.0",
    "@react-jvectormap/core": "^1.0.4",
    "@react-jvectormap/world": "^1.1.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/postcss": "^4.0.9",
    "@tanstack/query-sync-storage-persister": "^5.90.11",
    "@tanstack/react-query": "^5.90.9",
    "@tanstack/react-query-persist-client": "^5.90.11",
    "@types/next-auth": "^3.15.0",
    "apexcharts": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "axios": "^1.13.1",
    "firebase": "^11.10.0",
    "flatpickr": "^4.6.13",
    "libphonenumber-js": "^1.12.33",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "react": "^19.2.0",
    "react-apexcharts": "^1.7.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.3.5",
    "react-hot-toast": "^2.6.0",
    "swiper": "^11.2.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-transition-group": "^4.4.12",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "firebase-tools": "^13.0.0",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5",
    "wrangler": "^4.73.0"
  },
  "overrides": {
    "@react-jvectormap/core": {
      "react": "^16.8.0 || ^17 || ^18 || ^19",
      "react-dom": "^16.8.0 || ^17 || ^18 || ^19"
    },
    "@react-jvectormap/world": {
      "react": "^16.8.0 || ^17 || ^18 || ^19",
      "react-dom": "^16.8.0 || ^17 || ^18 || ^19"
    }
  }
}
