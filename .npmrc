# NestJS deps mix v10 (core/common/testing/schematics) and v11 (platform-express/cli/etc.),
# which npm's strict peer resolver rejects. The project is intended to install with legacy
# peer resolution (a lockfile already encodes that resolution). Keep this so `npm install`
# (and any preview/dev-server tooling that re-installs) works without a manual flag.
legacy-peer-deps=true
