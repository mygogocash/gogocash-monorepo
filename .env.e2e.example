# Copy values into apps/api/.env, apps/admin/.env.local, apps/app/.env for local E2E.
# Mongo: npm run e2e:up starts docker-compose.e2e.yml (replica set rs0).

# ── API (apps/api/.env) ──
MONGO_URI=mongodb://localhost:27017/gogocash-e2e?replicaSet=rs0
JWT_SECRET=e2e-local-jwt-secret-change-me
JWT_ADMIN_SECRET=e2e-local-admin-jwt-secret-change-me
PORT=8080
STRIPE_BILLING_ENABLED=false
# Set on local API only (e2e-stack.sh); ignored when NODE_ENV=production.
E2E_DISABLE_RATE_LIMIT=1

# ── Admin (apps/admin/.env.local) ──
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=e2e-local-nextauth-secret-change-me
NEXT_PUBLIC_APP_URL=http://localhost:8081

# ── Customer app (apps/app/.env) ──
EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_ACCOUNT_DATA_SOURCE=backend
EXPO_PUBLIC_FRONTEND_URL=http://localhost:8081
EXPO_PUBLIC_APP_ENV=development
