# Core
PORT=8080
MONGO_URI=mongodb://localhost:27017/gogocash
JWT_SECRET=replace-with-a-long-random-string
JWT_ADMIN_SECRET=replace-with-a-second-random-string

# Auth + identity
FIREBASE_PROJECT_ID=your-firebase-project-id
CROSSMINT_AUTH_BASE=
CROSSMINT_PROJECT_ID=
CROSSMINT_SECRET=
TELEGRAM_BOT_TOKEN=
WEB_APP_URL=http://localhost:3000
# Email OTP (nodemailer via Gmail) — real values go to Secret Manager, never here
GMAIL_USER=
GMAIL_APP_PASSWORD=
API_BASE_URL=http://localhost:8080

# PostHog product analytics
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ENABLED=true
POSTHOG_DEBUG=false

# Customer.io — lifecycle + transactional emails (Phase 1+)
# Service is null-safe: leave keys blank and identify/track/sendTransactional no-op.
# CUSTOMERIO_REGION: 'us' (default) or 'eu' — must match the workspace region in C.io settings.
CUSTOMERIO_SITE_ID=
CUSTOMERIO_TRACK_API_KEY=
CUSTOMERIO_APP_API_KEY=
CUSTOMERIO_WEBHOOK_SECRET=
CUSTOMERIO_REGION=us
# Phase 2+ — transactional template IDs from C.io console (numeric).
CUSTOMERIO_TEMPLATE_OTP_LOGIN_TH=
CUSTOMERIO_TEMPLATE_OTP_LOGIN_EN=
CUSTOMERIO_TEMPLATE_WELCOME_TH=
CUSTOMERIO_TEMPLATE_WELCOME_EN=
CUSTOMERIO_TEMPLATE_WITHDRAW_REQUESTED_TH=
CUSTOMERIO_TEMPLATE_WITHDRAW_REQUESTED_EN=
CUSTOMERIO_TEMPLATE_WITHDRAW_PAID_TH=
CUSTOMERIO_TEMPLATE_WITHDRAW_PAID_EN=
# Phase 5 — Telegram admin alert groups (reuses existing TELEGRAM_BOT_TOKEN).
TG_OPS_WITHDRAWALS_CHAT_ID=
TG_ALERTS_CHAT_ID=

# Involve Asia
INVOLVE_SECRET=
INVOVLE_SECRET=
INVOVLE_SECRET_OLD=

# Customer billing (server-side Stripe for Expo customer app)
STRIPE_BILLING_ENABLED=false
STRIPE_SECRET_KEY=
CUSTOMER_FRONTEND_URL=https://app.gogocash.co
STRIPE_PRICE_THB_MONTHLY=
STRIPE_PRICE_THB_ANNUAL=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Optimise Media affiliate network
# API key lives in Google Secret Manager (gogocash-{env}-optimise-api-key); do not commit real values.
OPTIMISE_API_KEY=
OPTIMISE_CONTACT_ID=2442123
OPTIMISE_AGENCY_ID=
OPTIMISE_API_BASE=https://api.optimisemedia.com

# Google Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# Withdrawal / on-chain
PRIVATE_KEY_WITHDRAW=
CHAIN_ID_WITHDRAW_POLYGON=
CHAIN_ID_WITHDRAW_BNB=
CHAIN_ID_WITHDRAW_SONIC=
CHAIN_ID_WITHDRAW_CELO=
RPC_URL_POLYGON=
RPC_URL_BNB=
RPC_URL_SONIC=
RPC_URL_CELO=
CONTRACT_WITHDRAW_ADDRESS_POLYGON=
