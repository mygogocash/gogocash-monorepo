# ─── Internal use only ───
# This app is configured to use mock data only (no real API).
# All data is served from /api/mock. Sign-in: admin@gogocash.co / 1234

# NextAuth secret used for JWT/session encryption
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Must match the URL you open in the browser (port = dev server port).
# Default `npm run dev` → 3000. Use `npm run dev:3001` → set to http://localhost:3001
NEXTAUTH_URL=http://localhost:3000

# Local development defaults
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Optional: extra hostnames for next/image optimization (comma-separated, no protocol)
# Must match your CDN or API file URLs. See docs/RUNBOOK.md.
# NEXT_PUBLIC_IMAGE_OPT_HOSTS=cdn.example.com,files.example.com
